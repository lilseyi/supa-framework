{
  "name": "@supa/notifications",
  "version": "0.1.0",
  "description": "Push notification infrastructure for Supa apps — provider, hooks, and handlers for Expo + Convex",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "default": "./dist/providers/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./handlers": {
      "types": "./dist/handlers/index.d.ts",
      "default": "./dist/handlers/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "expo-constants": ">=17.0.0",
    "expo-device": ">=7.0.0",
    "expo-notifications": ">=0.29.0",
    "expo-router": ">=4.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "peerDependenciesMeta": {
    "expo-notifications": {
      "optional": true
    },
    "expo-device": {
      "optional": true
    },
    "expo-constants": {
      "optional": true
    }
  },
  "license": "MIT"
}
