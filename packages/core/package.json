{
  "name": "@supa/core",
  "version": "0.1.0",
  "description": "Runtime core for the Supa framework — providers, hooks, and navigation for Convex + Expo apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "default": "./dist/providers/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./navigation": {
      "types": "./dist/navigation/index.d.ts",
      "default": "./dist/navigation/index.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "default": "./dist/forms/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@convex-dev/auth": ">=0.0.62",
    "@react-native-community/netinfo": ">=11.0.0",
    "@react-navigation/bottom-tabs": ">=7.0.0",
    "convex": ">=1.13.0",
    "expo": ">=52.0.0",
    "expo-secure-store": ">=14.0.0",
    "expo-updates": ">=0.26.0",
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "react-native-keyboard-controller": ">=1.0.0",
    "react-native-safe-area-context": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "expo-updates": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "@react-native-community/netinfo": {
      "optional": true
    },
    "react-native-keyboard-controller": {
      "optional": true
    },
    "@react-navigation/bottom-tabs": {
      "optional": true
    }
  },
  "license": "MIT"
}
